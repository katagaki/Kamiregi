{
  "sourceLanguage" : "ja",
  "strings" : {
    "%@ · %@" : {
      "comment" : "A line of text that includes the venue name and booth number of the event.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ · %2$@"
          }
        }
      }
    },
    "%@ × %lld" : {
      "comment" : "A line item in a payment confirmation view. The text is a concatenation of the item name and the quantity purchased.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ × %2$lld"
          }
        }
      }
    },
    "%lld" : {
      "comment" : "A label displaying the number of transactions made on a given day. The argument is the number of transactions made on that day.",
      "isCommentAutoGenerated" : true
    },
    "%lld / %lld · %@" : {
      "comment" : "A label showing the number of items sold and the initial stock, followed by the total revenue.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$lld / %2$lld · %3$@"
          }
        }
      }
    },
    "%lld%%" : {
      "comment" : "A percentage of sold items out of the initial stock.",
      "isCommentAutoGenerated" : true
    },
    "¥" : {
      "comment" : "Yen sign.",
      "isCommentAutoGenerated" : true
    },
    "0" : {
      "comment" : "A placeholder text for the amount paid in the payment sheet.",
      "isCommentAutoGenerated" : true
    },
